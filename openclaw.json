{
  "agents": {
    "defaults": {
      "workspace": "./workspace"
    },
    "list": [
      {
        "id": "kavana",
        "workspace": "./workspace",
        "runtime": {
          "type": "standard"
        }
      }
    ]
  },
  "cron": {
    "enabled": true,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789
  }
}
